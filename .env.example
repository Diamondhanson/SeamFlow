# SeamFlow root .env.example
# Copy to .env (which is gitignored) and fill in real values.
# Per-app .env files may override these where it makes sense.

# --- Supabase (used by the API and by Supabase JS clients on web/mobile) ---
# Public — safe to expose in client bundles.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=

# Server-only — never ship to client bundles. Used by apps/seamflow-api.
SUPABASE_SERVICE_ROLE_KEY=

# Project reference (the slug in your Supabase project URL).
# Used by the supabase CLI; can also be derived from SUPABASE_URL.
SUPABASE_PROJECT_REF=

# --- Future (filled in during later Phase 0 steps) ---
# DATABASE_URL=postgres://...
# REDIS_URL=...
# SENTRY_DSN=
# STRIPE_SECRET_KEY=
# PAYSTACK_SECRET_KEY=
# EXPO_ACCESS_TOKEN=
