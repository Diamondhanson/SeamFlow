{
  "name": "seamflow-web",
  "version": "0.1.0",
  "private": true,
  "description": "Client-facing web app — Phase 1.5 magic-link order view; future lookbook + public site.",
  "scripts": {
    "dev": "next dev -p 3000",
    "prebuild": "pnpm --filter \"seamflow-web^...\" build",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "tsc --noEmit",
    "clean": "rm -rf .next .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@seamflow/schemas": "workspace:*",
    "@seamflow/api-client": "workspace:*",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.5.0"
  }
}
