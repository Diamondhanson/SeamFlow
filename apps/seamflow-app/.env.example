# Android emulator: http://10.0.2.2:3001 (NOT localhost)
# iOS simulator: http://localhost:3001
# Physical device on same LAN: http://<machine-ip>:3001
EXPO_PUBLIC_API_URL=http://10.0.2.2:3001

EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional: enables the "Continue as dev" button on the sign-in screen.
EXPO_PUBLIC_DEV_EMAIL=
EXPO_PUBLIC_DEV_PASSWORD=

# Marketing + legal site (roadmap 3.12) — opened by the in-app Privacy/Terms links.
# Prod default is https://seamflow.app. For local testing against the web dev
# server, point it at the host: Android emulator http://10.0.2.2:3000
EXPO_PUBLIC_WEB_URL=https://seamflow.app
