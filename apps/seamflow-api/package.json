{
  "name": "seamflow-api",
  "version": "0.1.0",
  "private": true,
  "description": "SeamFlow NestJS API — REST backend, payments webhooks, background jobs.",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:auth": "node --env-file=.env --experimental-strip-types --no-warnings=ExperimentalWarning scripts/test-auth.ts",
    "test:domain": "node --env-file=.env --experimental-strip-types --no-warnings=ExperimentalWarning scripts/test-domain.ts",
    "test:groups": "node --env-file=.env --experimental-strip-types --no-warnings=ExperimentalWarning scripts/test-groups.ts",
    "test:orders": "node --env-file=.env --experimental-strip-types --no-warnings=ExperimentalWarning scripts/test-orders.ts",
    "test:sync": "node --env-file=.env --experimental-strip-types --no-warnings=ExperimentalWarning scripts/test-sync.ts",
    "test:share-links": "node --env-file=.env --experimental-strip-types --no-warnings=ExperimentalWarning scripts/test-share-links.ts",
    "test:notifications": "node --env-file=.env --experimental-strip-types --no-warnings=ExperimentalWarning scripts/test-notifications.ts",
    "test:groups-atomic": "node --env-file=.env --experimental-strip-types --no-warnings=ExperimentalWarning scripts/test-groups-atomic.ts",
    "test:search-filters": "node --env-file=.env --experimental-strip-types --no-warnings=ExperimentalWarning scripts/test-search-filters.ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^4.0.2",
    "@seamflow/schemas": "workspace:*",
    "@seamflow/types": "workspace:*",
    "@seamflow/utils": "workspace:*",
    "@sentry/nestjs": "^8.30.0",
    "@sentry/node": "^8.30.0",
    "@sentry/profiling-node": "^8.30.0",
    "@supabase/supabase-js": "^2.45.0",
    "bullmq": "^5.12.0",
    "drizzle-orm": "^0.33.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.3",
    "nestjs-zod": "^3.0.0",
    "postgres": "^3.4.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.24.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
