NODE_ENV=development
PORT=3001

# Supabase — required
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres — required for Drizzle ORM
# Supabase dashboard → Settings → Database → Connection string → URI (Transaction, port 6543)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Redis — optional. If empty, BullMQ queues are disabled and /health reports redis: "disabled".
# Upstash dashboard → Connect → standard rediss:// URL (port 6379 with TLS)
REDIS_URL=

# Sentry — optional. If empty, error tracking is disabled.
SENTRY_DSN=

# Anthropic (Claude) — optional. Powers AI "auto-describe" (image → text).
# If empty, POST /ai/describe-image returns 503 and the API still boots.
# Get a key + $5 free credit at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Share-link signing — required for Phase 1.5 magic links.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SHARE_LINK_JWT_SECRET=

# Base URL of seamflow-web for building share URLs in the API responses.
# Dev: http://localhost:3000. Prod: https://seamflow.app (eventually).
WEB_BASE_URL=http://localhost:3000
